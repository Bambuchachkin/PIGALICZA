server {
    listen 80;
    server_name pigalica.abrdns.com www.pigalica.abrdns.com 31.56.196.252;

    # Папка, где будут лежать статические файлы (HTML, CSS, JS)
    root /var/www/mysite;
    index index.html;

    # Обработка статических файлов
    location / {
        try_files $uri $uri/ =404;
    }

    # Перенаправление всех запросов к API на C++ сервер
    location /api/ {
    proxy_pass http://localhost:8080;   # без слеша на конце
    proxy_set_header Host $host;
    proxy_set_header X-Real-IP $remote_addr;
    }
}
