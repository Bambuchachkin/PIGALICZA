CXX = g++
CXXFLAGS = -std=c++17 -I/usr/local/include
LDFLAGS = 
LDLIBS = -lmysqlcppconn -lpthread -lssl -lcrypto -lboost_system

TARGET = my_server
SRCS = main.cpp database.cpp functions.cpp
OBJS = $(SRCS:.cpp=.o)
HEADERS = database.h functions.h

all: $(TARGET)

$(TARGET): $(OBJS)
	$(CXX) $(LDFLAGS) -o $@ $^ $(LDLIBS)

%.o: %.cpp $(HEADERS)
	$(CXX) $(CXXFLAGS) -c $< -o $@

clean:
	rm -f $(OBJS) $(TARGET)

.PHONY: all clean